# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ElevenLabs — voice narration in the dashboard
ELEVENLABS_API_KEY=

# MongoDB Atlas (optional — falls back to local JSON files if blank)
MONGODB_URI=

# Anthropic API — hosted LLM fallback when Ollama / GX10 is unavailable
ANTHROPIC_API_KEY=

# Fetch.ai Agentverse — required to register the Coordinator so ASI:One can find it
# Get this at: https://agentverse.ai → Settings → API Keys
AGENTVERSE_KEY=

# Fetch.ai ASI:One — Coordinator agent registration (legacy key name, kept for reference)
ASI_ONE_API_KEY=

# LLM — Ollama running on the ASUS Ascent GX10 (or any machine on the same host)
# Pull the model first: ollama pull gemma3
# Override LLM_BASE_URL if Ollama is running on a different host or port
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3

# FastAPI backend URL consumed by the dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
